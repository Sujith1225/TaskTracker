<div class="toast" id="toast"></div>

<script>
// ── Keys ──────────────────────────────────────────────────────────────────
const KEY_TASKS   = 'st_tasks';
const KEY_PROFILE = 'st_profile';
const KEY_STYLE   = 'st_inputStyle';
const KEY_THEME   = 'st_theme';
const KEY_DARK    = 'st_dark';
const KEY_HISTORY = 'st_history';

// ── Default tasks ─────────────────────────────────────────────────────────
const DEFAULT_TASKS = [];

// ── State ─────────────────────────────────────────────────────────────────
let TASKS       = [];
let counts      = {};
let autoOverrides = {};
let SHIFT_MINS  = 420;
let inputStyle  = 'pm';

// ── Load everything from localStorage ────────────────────────────────────
function loadAll() {
  // Tasks
  try {
    const saved = JSON.parse(localStorage.getItem(KEY_TASKS));
    TASKS = (saved && saved.length) ? saved : JSON.parse(JSON.stringify(DEFAULT_TASKS));
  } catch { TASKS = JSON.parse(JSON.stringify(DEFAULT_TASKS)); }
  counts = {}; TASKS.forEach(t => counts[t.id] = 0);

  // Profile
  try {
    const p = JSON.parse(localStorage.getItem(KEY_PROFILE) || '{}');
    if (p.name)     { document.getElementById('userName').value   = p.name; document.getElementById('headerSub').textContent = p.name; }
    if (p.client)   { document.getElementById('clientName').value = p.client; }
    if (p.shiftHrs) {
      const el = document.getElementById('shiftHrs');
      if (el) el.value = p.shiftHrs;
      SHIFT_MINS = Math.round(p.shiftHrs * 60);
    }
  } catch {}

  // Input style
  inputStyle = localStorage.getItem(KEY_STYLE) || 'pm';
  if (!['pm','slider'].includes(inputStyle)) inputStyle = 'pm';

  // Theme
  applyTheme(localStorage.getItem(KEY_THEME) || 'indigo', false);

  // Dark
  if (localStorage.getItem(KEY_DARK) === '1') {
    document.body.classList.add('dark');
    document.getElementById('opt-dark').classList.add('active');
    document.getElementById('chk-dark').textContent = '✓';
  }

  updateProgressTitle();
}

// ── Profile save ──────────────────────────────────────────────────────────
function saveProfile() {
  const name     = document.getElementById('userName').value.trim();
  const client   = document.getElementById('clientName').value.trim();
  const shiftHrs = parseFloat(document.getElementById('shiftHrs').value) || 7;
  localStorage.setItem(KEY_PROFILE, JSON.stringify({ name, client, shiftHrs }));
  document.getElementById('headerSub').textContent = name || 'Daily Work Time Monitor';
}

// ── Shift hours change ────────────────────────────────────────────────────
function onShiftChange() {
  const hrs = parseFloat(document.getElementById('shiftHrs').value) || 7;
  SHIFT_MINS = Math.round(Math.max(0.5, Math.min(24, hrs)) * 60);
  saveProfile();
  updateProgressTitle();
  autoOverrides = {};
  buildCards();
  recalc();
}

function updateProgressTitle() {
  document.getElementById('progressTitle').textContent =
    `Task Load vs Shift Capacity (${SHIFT_MINS} mins)`;
  document.getElementById('sumFree').textContent = SHIFT_MINS;
}

// ── Save tasks ────────────────────────────────────────────────────────────
function saveTasks() { localStorage.setItem(KEY_TASKS, JSON.stringify(TASKS)); }

// ── Add task ──────────────────────────────────────────────────────────────
function addTask() {
  const nameEl = document.getElementById('newTaskName');
  const minsEl = document.getElementById('newTaskMins');
  const autoEl = document.getElementById('newTaskAuto');
  const name   = nameEl.value.trim();
  const mins   = parseInt(minsEl.value) || 0;
  if (!name) { showToast('⚠ Enter a task name!'); nameEl.focus(); return; }
  if (mins < 1) { showToast('⚠ Enter minutes (min 1)!'); minsEl.focus(); return; }
  const id = 'task_' + Date.now();
  TASKS.push({ id, name, mins, auto: autoEl.checked });
  counts[id] = 0;
  nameEl.value = ''; minsEl.value = ''; autoEl.checked = false;
  saveTasks(); buildCards(); recalc();
  showToast(`✅ "${name}" added!`);
}

// ── Delete task ───────────────────────────────────────────────────────────
function deleteTask(id) {
  if (TASKS.length <= 1) { showToast('⚠ Need at least one task!'); return; }
  const t = TASKS.find(x => x.id === id);
  if (!confirm(`Remove "${t?.name}"?`)) return;
  TASKS = TASKS.filter(x => x.id !== id);
  delete counts[id]; delete autoOverrides[id];
  saveTasks(); buildCards(); recalc();
  showToast(`🗑 "${t?.name}" removed`);
}

// ── Build input widget ────────────────────────────────────────────────────
function buildInput(t) {
  const val = counts[t.id] || 0;
  const max = Math.max(1, Math.floor(SHIFT_MINS / t.mins));
  if (inputStyle === 'pm') return `
    <div class="counter-widget">
      <button class="counter-btn" onclick="setCount('${t.id}',(counts['${t.id}']||0)-1)">−</button>
      <input type="number" class="counter-num" id="inp_${t.id}" value="${val||''}" placeholder="—" min="0" max="${max}" oninput="setCount('${t.id}',+this.value)"/>
      <button class="counter-btn" onclick="setCount('${t.id}',(counts['${t.id}']||0)+1)">+</button>
    </div>`;
  if (inputStyle === 'slider') return `
    <div class="slider-wrap">
      <div class="slider-top">
        <span style="font-size:0.68rem;color:var(--muted);font-weight:500">Count</span>
        <span class="slider-val" id="sv_${t.id}">${val}</span>
      </div>
      <input type="range" class="task-slider" id="inp_${t.id}" min="0" max="${max}" value="${val}"
        oninput="setCount('${t.id}',+this.value);document.getElementById('sv_${t.id}').textContent=this.value"/>
      <div class="slider-minmax"><span>0</span><span>${max}</span></div>
    </div>`;
  return '';
}

// ── Build auto input ──────────────────────────────────────────────────────
function buildAutoInput(t) {
  return `
    <div style="width:100%">
      <div class="counter-widget auto-widget-editable" style="margin-bottom:6px">
        <button class="counter-btn" onclick="adjustAuto('${t.id}',-1)">−</button>
        <input type="number" class="counter-num" id="inp_${t.id}" value="${counts[t.id]||0}" min="0" oninput="onAutoInput('${t.id}',this.value)"/>
        <button class="counter-btn" onclick="adjustAuto('${t.id}',1)">+</button>
      </div>
      <div class="auto-reset-row">
        <span class="auto-calc-info" id="autoInfo_${t.id}">⚙ Auto</span>
        <button class="auto-reset-btn" onclick="resetAutoTask('${t.id}')">↺ Reset to Auto</button>
      </div>
    </div>`;
}

// ── Build cards ───────────────────────────────────────────────────────────
function buildCards() {
  const grid = document.getElementById('taskGrid');
  grid.innerHTML = '';
  TASKS.forEach(t => {
    const card = document.createElement('div');
    card.className = 'task-card' + (t.auto ? ' auto-card' : '');
    card.innerHTML = `
      <div class="task-top">
        <div class="task-name">${t.name}${t.auto ? ` <span class="auto-badge">Auto</span>` : ''}</div>
        <div class="task-rate">${t.mins} min/task</div>
        <button class="task-del-btn" onclick="deleteTask('${t.id}')" title="Remove task">✕</button>
      </div>
      ${t.auto ? '<div class="auto-hint">⚡ Fills remaining shift time automatically</div>' : ''}
      <div class="task-input-row">
        <div class="task-count-label">Tasks:</div>
        ${t.auto ? buildAutoInput(t) : buildInput(t)}
      </div>
      <div class="task-result">
        <div>
          <div class="task-mins" id="res_mins_${t.id}">0 mins</div>
          <div class="task-hrs" id="res_hrs_${t.id}">0hr 0min</div>
        </div>
        <div style="text-align:right;font-family:'Space Mono',monospace;font-size:0.65rem;color:var(--muted)">
          Max/shift: <span style="color:var(--text2);font-weight:600">${Math.floor(SHIFT_MINS/t.mins)}</span>
        </div>
      </div>
      <div class="task-bar"><div class="task-bar-fill" id="bar_${t.id}" style="width:0%"></div></div>`;
    grid.appendChild(card);
  });
}

// ── Set count ─────────────────────────────────────────────────────────────
function setCount(id, val) {
  counts[id] = Math.max(0, Math.floor(+val) || 0);
  const inp = document.getElementById('inp_' + id);
  if (inp && inputStyle === 'pm') inp.value = counts[id] === 0 ? '' : counts[id];
  if (inp && inputStyle === 'slider') inp.value = counts[id];
  recalc();
}

// ── Auto task controls ────────────────────────────────────────────────────
function adjustAuto(id, delta) {
  autoOverrides[id] = true;
  counts[id] = Math.max(0, (counts[id]||0) + delta);
  document.getElementById('inp_'+id).value = counts[id];
  recalc();
}
function onAutoInput(id, val) {
  autoOverrides[id] = true;
  counts[id] = Math.max(0, parseInt(val)||0);
  recalc();
}
function resetAutoTask(id) {
  autoOverrides[id] = false;
  recalc();
}

// ── Recalculate ───────────────────────────────────────────────────────────
function fmtHrMin(m) { return `${Math.floor(m/60)}hr ${m%60}min`; }

function recalc() {
  // Manual mins (non-auto tasks)
  let manualMins = 0;
  TASKS.filter(t => !t.auto).forEach(t => { manualMins += (counts[t.id]||0) * t.mins; });

  // Auto tasks share remaining time
  const autoTasks = TASKS.filter(t => t.auto);
  let remaining = Math.max(0, SHIFT_MINS - manualMins);
  autoTasks.forEach(t => {
    const autoVal = Math.floor(remaining / t.mins);
    if (!autoOverrides[t.id]) {
      counts[t.id] = autoVal;
      const el = document.getElementById('inp_'+t.id);
      if (el) el.value = autoVal;
    }
    const info = document.getElementById('autoInfo_'+t.id);
    if (info) {
      info.textContent = autoOverrides[t.id] ? `⚙ Auto: ${autoVal} (overridden)` : `⚙ Auto: ${autoVal} tasks`;
      info.style.color = autoOverrides[t.id] ? 'var(--warn)' : 'var(--accent)';
    }
    remaining = Math.max(0, remaining - counts[t.id] * t.mins);
  });

  // Totals
  let totalMins = 0, totalTasks = 0;
  TASKS.forEach(t => {
    const c = counts[t.id]||0, m = c * t.mins;
    totalMins += m; totalTasks += c;
    const rm = document.getElementById('res_mins_'+t.id); if(rm) rm.textContent = m+' mins';
    const rh = document.getElementById('res_hrs_'+t.id);  if(rh) rh.textContent = fmtHrMin(m);
    const br = document.getElementById('bar_'+t.id);      if(br) br.style.width = Math.min(100,(m/SHIFT_MINS)*100)+'%';
  });

  const free = SHIFT_MINS - totalMins, pct = (totalMins/SHIFT_MINS)*100;
  document.getElementById('sumTasks').textContent = totalTasks;
  document.getElementById('sumMins').textContent  = totalMins;
  document.getElementById('sumHrs').textContent   = fmtHrMin(totalMins);
  document.getElementById('sumFree').textContent  = Math.max(0,free);
  document.getElementById('sumFree').className    = 'sum-val '+(free<0?'red':free<60?'yellow':'green');
  const prog = document.getElementById('taskProgress'), pctEl = document.getElementById('taskPct');
  prog.style.width  = Math.min(100,pct)+'%';
  prog.className    = 'progress-fill '+(pct>100?'over':pct>85?'warn':'ok');
  pctEl.textContent = pct.toFixed(1)+'%';
  pctEl.style.color = pct>100?'var(--accent2)':pct>85?'var(--warn)':'var(--accent3)';
  const sb = document.getElementById('sumStatus');
  if(pct>100){sb.className='status-badge status-over';sb.textContent='🔴 Exceeds Shift';}
  else if(pct>85){sb.className='status-badge status-warn';sb.textContent='⚠ Near Limit';}
  else{sb.className='status-badge status-ok';sb.textContent='✅ On Track';}
}

// ── Settings ──────────────────────────────────────────────────────────────
function openSettings() {
  document.getElementById('settingsOverlay').classList.add('open');
  document.getElementById('settingsDrawer').classList.add('open');
  buildDurSettings();
}
function closeSettings() {
  document.getElementById('settingsOverlay').classList.remove('open');
  document.getElementById('settingsDrawer').classList.remove('open');
}

// ── Input style ───────────────────────────────────────────────────────────
function setInputStyle(s) {
  inputStyle = s;
  localStorage.setItem(KEY_STYLE, s);
  ['pm','slider'].forEach(x => {
    document.getElementById('opt-'+x).classList.toggle('active', x===s);
    document.getElementById('chk-'+x).textContent = x===s ? '✓' : '';
  });
  buildCards(); recalc();
  showToast('✅ Input style updated!');
}

// ── Duration settings ─────────────────────────────────────────────────────
function buildDurSettings() {
  const c = document.getElementById('durSettings');
  if (!c) return;
  c.innerHTML = TASKS.map(t => `
    <div class="dur-row">
      <div class="dur-name">${t.name}</div>
      <div class="dur-wrap">
        <input type="number" class="dur-input" id="dur_${t.id}" value="${t.mins}" min="1" max="999"
          oninput="updateDuration('${t.id}',this.value)"/>
        <span class="dur-unit">min</span>
      </div>
    </div>`).join('');
}

function updateDuration(id, val) {
  const mins = Math.max(1, parseInt(val)||1);
  const task = TASKS.find(t => t.id===id);
  if (!task) return;
  task.mins = mins;
  saveTasks();
  autoOverrides = {};
  buildCards(); recalc();
}

function resetDurations() {
  DEFAULT_TASKS.forEach(dt => {
    const t = TASKS.find(x => x.id===dt.id);
    if (t) t.mins = dt.mins;
  });
  saveTasks(); buildDurSettings(); buildCards(); recalc();
  showToast('↺ Durations reset to defaults!');
}

// ── Themes ────────────────────────────────────────────────────────────────
const THEMES = [
  {id:'indigo', accent:'#6366f1', light:'#eef2ff'},
  {id:'violet', accent:'#8b5cf6', light:'#f5f3ff'},
  {id:'rose',   accent:'#f43f5e', light:'#fff1f2'},
  {id:'orange', accent:'#f97316', light:'#fff7ed'},
  {id:'teal',   accent:'#14b8a6', light:'#f0fdfa'},
  {id:'sky',    accent:'#0ea5e9', light:'#f0f9ff'},
  {id:'emerald',accent:'#10b981', light:'#ecfdf5'},
  {id:'slate',  accent:'#475569', light:'#f8fafc'},
];
function buildThemeSwatches() {
  const cur = localStorage.getItem(KEY_THEME) || 'indigo';
  document.getElementById('themeRow').innerHTML = THEMES.map(th =>
    `<div class="swatch${th.id===cur?' active':''}" id="sw-${th.id}" style="background:${th.accent}" title="${th.id}"
      onclick="applyTheme('${th.id}',true)"></div>`).join('');
}
function applyTheme(id, save) {
  const th = THEMES.find(x=>x.id===id)||THEMES[0];
  document.documentElement.style.setProperty('--accent', th.accent);
  document.documentElement.style.setProperty('--accent-light', th.light);
  if (save) {
    localStorage.setItem(KEY_THEME, id);
    document.querySelectorAll('.swatch').forEach(s=>s.classList.remove('active'));
    const sw = document.getElementById('sw-'+id);
    if (sw) sw.classList.add('active');
    showToast('🎨 Theme updated!');
  }
}

// ── Dark mode ─────────────────────────────────────────────────────────────
function toggleDark() {
  const isDark = document.body.classList.toggle('dark');
  document.getElementById('opt-dark').classList.toggle('active', isDark);
  document.getElementById('chk-dark').textContent = isDark ? '✓' : '';
  localStorage.setItem(KEY_DARK, isDark ? '1' : '0');
  showToast(isDark ? '🌙 Dark mode on' : '☀️ Light mode on');
}

// ── Clock ─────────────────────────────────────────────────────────────────
function tickClock() {
  const now = new Date();
  document.getElementById('liveClock').textContent =
    [now.getHours(),now.getMinutes(),now.getSeconds()].map(n=>String(n).padStart(2,'0')).join(':');
}
setInterval(tickClock, 1000); tickClock();

// ── Save / Export / Reset ─────────────────────────────────────────────────
function saveToday() {
  const now    = new Date();
  const name   = document.getElementById('userName').value.trim();
  const client = document.getElementById('clientName').value.trim();
  const dateStr = now.toLocaleDateString('en-IN',{weekday:'short',day:'2-digit',month:'short',year:'numeric'});
  const timeStr = now.toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit'});
  let totalMins=0, totalTasks=0;
  const taskSnap = {};
  TASKS.forEach(t=>{
    taskSnap[t.id] = {name:t.name, count:counts[t.id], mins:t.mins};
    totalTasks += counts[t.id];
    totalMins  += counts[t.id]*t.mins;
  });
  const h = getHistory();
  h.unshift({date:dateStr,time:timeStr,name,client,tasks:taskSnap,totalTasks,totalMins});
  localStorage.setItem(KEY_HISTORY, JSON.stringify(h.slice(0,30)));
  renderHistory(); showToast('✅ Record saved!');
}

function getHistory(){try{return JSON.parse(localStorage.getItem(KEY_HISTORY)||'[]');}catch{return[];}}

function renderHistory(){
  const list = document.getElementById('historyList'), h = getHistory();
  if(!h.length){list.innerHTML='<div class="empty-history">No records yet — save a record to start tracking.</div>';return;}
  list.innerHTML = h.map((r,i)=>`
    <div class="history-item">
      <div class="history-date">${r.date} · ${r.time}</div>
      ${r.name||r.client ? `<div class="history-client">${[r.name,r.client].filter(Boolean).join(' — ')}</div>` : ''}
      <div class="history-tasks">
        ${Object.values(r.tasks||{}).filter(t=>t.count>0).map(t=>`<span class="history-tag">${t.name.split(' ')[0]}: ${t.count}</span>`).join('')}
      </div>
      <div class="history-total">${r.totalMins}m · ${r.totalTasks} tasks</div>
      <button class="history-del" onclick="deleteRecord(${i})">✕</button>
    </div>`).join('');
}

function deleteRecord(i){const h=getHistory();h.splice(i,1);localStorage.setItem(KEY_HISTORY,JSON.stringify(h));renderHistory();}

function exportCSV(){
  const h = getHistory();
  if(!h.length){showToast('No records to export yet.');return;}
  const allNames = [...new Set(h.flatMap(r=>Object.values(r.tasks||{}).map(t=>t.name)))];
  let csv = 'Date,Time,Name,Client,'+allNames.join(',')+',Total Tasks,Total Mins,Total Hours\n';
  h.forEach(r=>{
    const m={};
    Object.values(r.tasks||{}).forEach(t=>m[t.name]=t.count);
    csv+=`"${r.date}","${r.time}","${r.name||''}","${r.client||''}",`+allNames.map(n=>m[n]||0).join(',')+`,${r.totalTasks},${r.totalMins},${(r.totalMins/60).toFixed(2)}\n`;
  });
  const blob=new Blob([csv],{type:'text/csv'}),url=URL.createObjectURL(blob),a=document.createElement('a');
  a.href=url;a.download='ShiftTrack_Records.csv';a.click();URL.revokeObjectURL(url);
  showToast('⬇ CSV downloaded!');
}

function resetCounts(){
  TASKS.forEach(t=>{counts[t.id]=0;});
  autoOverrides={};
  buildCards(); recalc(); showToast('Counts cleared.');
}

// ── Enter key shortcuts ───────────────────────────────────────────────────
document.getElementById('newTaskName').addEventListener('keydown',e=>{if(e.key==='Enter')document.getElementById('newTaskMins').focus();});
document.getElementById('newTaskMins').addEventListener('keydown',e=>{if(e.key==='Enter')addTask();});

// ── Toast ─────────────────────────────────────────────────────────────────
let toastTimer;
function showToast(msg){const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');clearTimeout(toastTimer);toastTimer=setTimeout(()=>t.classList.remove('show'),2500);}

// ── Init ──────────────────────────────────────────────────────────────────
loadAll();
setInputStyle(inputStyle);
buildCards();
recalc();
renderHistory();
</script>
